# Copy to .env and fill in your values. Never commit .env.

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/quantpilot

# Auth
JWT_SECRET=your-secret-key

# Alpha Vantage (stock data API - get free key at https://www.alphavantage.co/support/#api-key)
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key

# Finnhub (news + social sentiment - https://finnhub.io/register)
FINNHUB_API_KEY=your_finnhub_api_key

# Reddit PRAW (https://www.reddit.com/prefs/apps - create "script" app)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=QuantPilot/1.0

# Stocktwits: public API, no key needed. Optional for higher limits:
# STOCKTWITS_ACCESS_TOKEN=optional

# Market Data (options chain with reliable bid/ask - https://www.marketdata.app/)
# Free tier: 100 req/day. Set to enable; otherwise yfinance fallback is used.
# MARKETDATA_API_KEY=your_marketdata_api_key

# Options quant: default risk-free rate (decimal, e.g. 0.05 for 5%)
DEFAULT_RISK_FREE_RATE=0.05
